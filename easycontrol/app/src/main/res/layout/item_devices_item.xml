<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/background_cron"
  android:elevation="3dp"
  android:gravity="center"
  android:minHeight="70dp"
  android:orientation="horizontal"
  android:paddingStart="@dimen/cardPadding"
  android:paddingTop="14dp"
  android:paddingEnd="@dimen/cardPadding"
  android:paddingBottom="14dp">

  <ImageView
    android:id="@+id/device_icon"
    android:layout_width="34dp"
    android:layout_height="34dp"
    android:background="@drawable/option_card_background"
    android:padding="6dp"
    android:src="@drawable/wifi_checking_connection"
    android:tint="@color/button" />

  <TextView
    android:id="@+id/device_name"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="10dp"
    android:layout_weight="1"
    android:fontFamily="sans-serif-medium"
    android:includeFontPadding="false"
    android:maxLines="1"
    android:text="设备1"
    android:textColor="@color/onCardBackground"
    android:textSize="@dimen/largeFont"
    tools:ignore="HardcodedText" />

  <ImageView
    android:id="@+id/device_expand"
    android:layout_width="34dp"
    android:layout_height="34dp"
    android:background="@drawable/toolbar_icon_background"
    android:padding="7dp"
    android:rotation="180"
    android:src="@drawable/chevron_left"
    android:tint="@color/onBackgroundSecond" />

</LinearLayout>
