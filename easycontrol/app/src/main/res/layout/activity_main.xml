<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/background_app"
  android:orientation="vertical"
  android:paddingStart="@dimen/pagePadding"
  android:paddingEnd="@dimen/pagePadding">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="18dp">

    <ImageView
      android:id="@+id/button_set"
      android:layout_width="52dp"
      android:layout_height="52dp"
      android:background="@drawable/toolbar_icon_background"
      android:padding="14dp"
      android:src="@drawable/bars"
      android:tint="@color/onBackground" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:fontFamily="sans-serif-medium"
        android:includeFontPadding="false"
        android:text="@string/app_name"
        android:textColor="@color/onBackground"
        android:textSize="@dimen/largeFont" />

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="4dp"
        android:includeFontPadding="false"
        android:text="@string/main_poem"
        android:textColor="@color/onBackgroundSecond"
        android:textSize="@dimen/smallSmallFont" />
    </LinearLayout>

    <ImageView
      android:id="@+id/button_refresh"
      android:layout_width="52dp"
      android:layout_height="52dp"
      android:layout_marginStart="10dp"
      android:background="@drawable/toolbar_icon_background"
      android:padding="13dp"
      android:src="@drawable/refresh"
      android:tint="@color/onBackground" />

    <ImageView
      android:id="@+id/button_pair"
      android:layout_width="52dp"
      android:layout_height="52dp"
      android:layout_marginStart="10dp"
      android:background="@drawable/toolbar_icon_background"
      android:padding="14dp"
      android:src="@drawable/pair"
      android:tint="@color/onBackground" />

    <ImageView
      android:id="@+id/button_add"
      android:layout_width="52dp"
      android:layout_height="52dp"
      android:layout_marginStart="10dp"
      android:background="@drawable/toolbar_icon_background"
      android:padding="14dp"
      android:src="@drawable/plus"
      android:tint="@color/onBackground" />

  </LinearLayout>

  <ScrollView
    android:id="@+id/devices_list"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="60dp">

    <GridLayout
      android:id="@+id/devices_grid"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:alignmentMode="alignBounds"
      android:columnCount="4"
      android:orientation="horizontal"
      android:useDefaultMargins="false"
      tools:ignore="UselessParent"
      tools:listitem="@layout/item_device_card" />
  </ScrollView>

</LinearLayout>
