<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/background_cron"
  android:elevation="4dp"
  android:orientation="vertical"
  android:paddingStart="24dp"
  android:paddingTop="22dp"
  android:paddingEnd="24dp"
  android:paddingBottom="26dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/setting_icon"
      android:layout_width="42dp"
      android:layout_height="42dp"
      android:background="@drawable/toolbar_icon_background"
      android:padding="10dp"
      android:src="@drawable/ic_tune"
      android:tint="@color/onCardBackground" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="14dp"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/setting_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:includeFontPadding="false"
        android:textColor="@color/onCardBackground"
        android:textSize="@dimen/largeFont" />

      <TextView
        android:id="@+id/setting_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:includeFontPadding="false"
        android:textColor="@color/onCardBackgroundSecond"
        android:textSize="@dimen/smallFont" />
    </LinearLayout>

    <ImageView
      android:id="@+id/setting_close"
      android:layout_width="44dp"
      android:layout_height="44dp"
      android:layout_marginStart="14dp"
      android:background="@drawable/toolbar_icon_background"
      android:contentDescription="@string/dialog_close"
      android:padding="13dp"
      android:src="@drawable/x"
      android:tint="@color/onCardBackground" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/setting_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:orientation="vertical"
    android:paddingBottom="18dp" />
</LinearLayout>
