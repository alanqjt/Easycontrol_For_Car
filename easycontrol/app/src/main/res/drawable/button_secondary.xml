<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_pressed="true">
    <shape>
      <corners android:radius="@dimen/roundSmall" />
      <solid android:color="@color/surfacePressed" />
    </shape>
  </item>
  <item>
    <shape>
      <corners android:radius="@dimen/roundSmall" />
      <solid android:color="@color/buttonSecond" />
      <stroke android:width="1dp" android:color="@color/accentSoft" />
    </shape>
  </item>
</selector>
